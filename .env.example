# Envoi des demandes du formulaire de contact par email (service Resend)
# 1. Crée un compte gratuit sur https://resend.com avec l'adresse Propreeclat@gmail.com
# 2. Dans "API Keys", crée une clé et copie-la ci-dessous
# 3. Renseigne ces variables dans ton hébergeur (ou dans un fichier .env.local en local)

RESEND_API_KEY=

# Adresse qui reçoit les demandes (par défaut : Propreeclat@gmail.com)
CONTACT_TO_EMAIL=Propreeclat@gmail.com

# Expéditeur affiché. Tant que tu n'as pas de domaine vérifié dans Resend,
# garde l'expéditeur de test ci-dessous (fonctionne vers ta propre adresse Gmail) :
CONTACT_FROM_EMAIL=Propre Éclat <onboarding@resend.dev>
